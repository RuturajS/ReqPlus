{
  "manifest_version": 3,
  "name": "ReqPlus – Browser Security Toolkit",
  "version": "1.0.0",
  "description": "Lightweight in-browser security testing toolkit: Proxy, Repeater, Intruder – inspired by Burp Suite.",
  "permissions": [
    "webRequest",
    "storage",
    "activeTab",
    "tabs",
    "scripting",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background/proxy_engine.js"
  },
  "devtools_page": "devtools/devtools.html",
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["devtools/*", "ui/*", "styles/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
